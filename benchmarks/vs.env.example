# Head-to-head benchmark configuration (docs/BENCHMARKS_VS.md)
#
# Copy this file to `vs.env` next to it and edit. Both the shell scripts
# (run-vs.sh / run-vs.zsh) and the PowerShell script (run-vs.ps1) read it.
# `vs.env` is gitignored — your local paths never end up in a commit.

# --- required ---------------------------------------------------------------

# Absolute path to the LoCoMo dataset file. The dataset is user-supplied
# (research data, not redistributed here): https://github.com/snap-research/locomo
LOCOMO_JSON=

# --- what to run ------------------------------------------------------------

# System under test: mnemosyne | mem0 | supermemory
SYSTEM=mnemosyne

# Session-recall cutoff (published rows use 10)
K=10

# Shard controls: run only LIMIT conversations after skipping SKIP.
# Empty LIMIT = the whole dataset. Published subset rows used SKIP=0 LIMIT=2.
SKIP=0
LIMIT=

# Cap QA per conversation (0 = all). Useful for smoke-testing an adapter.
QA_LIMIT=0

# --- HTTP systems only (mem0 / supermemory) ---------------------------------

# Base URL of the competitor server, reachable FROM INSIDE a container —
# use host.docker.internal for a server on your host.
# Bring the stack up first: see deploy/bench-vs/README.md
VS_URL=http://host.docker.internal:8765

# --- optional: the neural-embedder mnemosyne row ----------------------------

# Set both to run the MiniLM row (still sealed, still no LLM). Model files
# are user-supplied MiniLM-class ONNX exports (see benchmarks/README.md).
ONNX_MODEL=
ONNX_TOKENIZER=
