{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "Mnemosyne — Palace",
  "uid": "mnemosyne-palace",
  "tags": ["mnemosyne"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "HMAC verify failures (tamper)",
      "description": "Any non-zero value means a record, KG triple, tunnel, or vault manifest failed HMAC verification on read.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(mnemosyne_hmac_verify_failures_total)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Drawers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(mnemosyne_drawers)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Audit chain height",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "max(mnemosyne_audit_chain_height)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "yellow" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Search rate (1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(mnemosyne_search_total[1m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "sum by (route) (rate(mnemosyne_http_requests_total[5m]))", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Search latency (p95 / p50)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(mnemosyne_search_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "B", "expr": "histogram_quantile(0.50, sum by (le) (rate(mnemosyne_search_duration_seconds_bucket[5m])))", "legendFormat": "p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Drawer writes by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "sum by (outcome) (rate(mnemosyne_drawer_writes_total[5m]))", "legendFormat": "{{outcome}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "wps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Audit-chain commits & HMAC failures (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(mnemosyne_chain_commits_total[5m]))", "legendFormat": "chain commits" },
        { "refId": "B", "expr": "sum(rate(mnemosyne_hmac_verify_failures_total[5m]))", "legendFormat": "hmac failures" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hmac failures" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      }
    }
  ]
}
