{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "Mnemosyne — Palace",
  "uid": "mnemosyne-palace",
  "tags": ["mnemosyne"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "HMAC verify failures (tamper)",
      "description": "Any non-zero value means a record, KG triple, tunnel, or vault manifest failed HMAC verification on read.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(mnemosyne_hmac_verify_failures_total)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Drawers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(mnemosyne_drawers)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Audit chain height",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "max(mnemosyne_audit_chain_height)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "yellow" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Search rate (1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(mnemosyne_search_total[1m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "sum by (route) (rate(mnemosyne_http_requests_total[5m]))", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Search latency (p95 / p50)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(mnemosyne_search_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "B", "expr": "histogram_quantile(0.50, sum by (le) (rate(mnemosyne_search_duration_seconds_bucket[5m])))", "legendFormat": "p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Drawer writes by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "sum by (outcome) (rate(mnemosyne_drawer_writes_total[5m]))", "legendFormat": "{{outcome}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "wps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Audit-chain commits & HMAC failures (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(mnemosyne_chain_commits_total[5m]))", "legendFormat": "chain commits" },
        { "refId": "B", "expr": "sum(rate(mnemosyne_hmac_verify_failures_total[5m]))", "legendFormat": "hmac failures" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hmac failures" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Integrity & alerting",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Tamper by surface (2m increase)",
      "description": "HMAC-verify failures grouped by surface: drawer / kg / tunnel / manifest.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "targets": [
        { "refId": "A", "expr": "sum by (surface) (increase(mnemosyne_hmac_verify_failures_total[2m]))", "legendFormat": "{{surface}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 }, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "targets": [
        { "refId": "A", "expr": "sum by (route) (rate(mnemosyne_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Auth rejections by kind",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "targets": [
        { "refId": "A", "expr": "sum by (kind) (rate(mnemosyne_auth_rejections_total[5m]))", "legendFormat": "{{kind}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "alertlist",
      "title": "Active alerts (Alertmanager)",
      "datasource": { "type": "alertmanager", "uid": "alertmanager" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "options": {
        "viewMode": "list",
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 3,
        "alertInstanceLabelFilter": "",
        "datasource": "Alertmanager",
        "stateFilter": { "firing": true, "pending": true, "normal": false, "error": true, "noData": false }
      }
    },
    {
      "type": "row",
      "title": "Logs & traces (metadata only)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "Mnemosyne logs (Loki)",
      "description": "Structured tracing logs — counts, routes, surfaces. Never drawer content or keys.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 40 },
      "targets": [
        { "refId": "A", "expr": "{service=\"mnemosyne\"}", "queryType": "range" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "type": "table",
      "title": "Recent traces (Tempo)",
      "description": "Request/search/save spans — metadata-only (vault id, route, op).",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 40 },
      "targets": [
        { "refId": "A", "queryType": "traceqlSearch", "query": "{ resource.service.name = \"mnemosyne\" }", "limit": 20, "tableType": "traces", "filters": [] }
      ]
    }
  ]
}
