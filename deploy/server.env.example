# Copy to deploy/.env and edit. Never commit deploy/.env.

# REQUIRED for a network-exposed bind: long random secret clients must send
# as "Authorization: Bearer <token>". Generate one:
#   openssl rand -hex 32
MNEMOSYNE_MCP_HTTP_TOKEN=

# Optional: derive the palace master key from a passphrase (Argon2id)
# instead of the generated key file inside the volume.
# MNEMOSYNE_PASSPHRASE=
